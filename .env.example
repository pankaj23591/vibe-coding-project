# Optional — real transcription + structured analysis (Whisper + chat model)
OPENAI_API_KEY=

# Project-scoped keys (sk-proj-...): set the project id from OpenAI dashboard → Project → General
# OPENAI_PROJECT_ID=proj_...

# Optional org id for some accounts
# OPENAI_ORG_ID=org_...

# Optional override for analysis model (default: gpt-4o-mini)
# OPENAI_ANALYSIS_MODEL=gpt-4o-mini

# MySQL — required for saving calls, transcripts, and analysis
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=vibe-coding-project

# Set to 1 to skip auto CREATE DATABASE (if your user already has an empty DB)
# MYSQL_SKIP_AUTOCREATE_DB=1
